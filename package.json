{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@jack-yang/opencode-tps-meter",
  "version": "0.1.0",
  "description": "Live TPS/AVG/TTFT meter plugin for OpenCode TUI with color-coded speed tiers",
  "type": "module",
  "exports": {
    "./tui": {
      "import": "./tui.tsx"
    }
  },
  "engines": {
    "opencode": ">=1.4.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.3",
    "@opentui/core": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "tui.tsx",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "tps",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yangwudong/opencode-tps-meter.git"
  },
  "homepage": "https://github.com/yangwudong/opencode-tps-meter#readme",
  "bugs": {
    "url": "https://github.com/yangwudong/opencode-tps-meter/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
